# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=havenhositing
DB_PASSWORD=your_secure_password_here
DB_NAME=havenhositing

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# Node Environment
NODE_ENV=development
PORT=5000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox

# GCash API
GCASH_API_KEY=your_gcash_api_key
GCASH_PARTNER_ID=your_partner_id

# Maya API
MAYA_API_KEY=your_maya_api_key
MAYA_SECRET_KEY=your_maya_secret

# Pterodactyl
PTERODACTYL_HOST=https://panel.example.com
PTERODACTYL_API_KEY=your_pterodactyl_api_key

# Cloudflare
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Email
EMAIL_SERVICE=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@havenhositing.com

# Security
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=debug

# Features
ENABLE_2FA=true
ENABLE_DDoS_PROTECTION=true
ENABLE_AUTO_BACKUPS=true
